# ─────────────────────────────────────────────────────────────
# JadeCapital v3 — Environment Variables
# ─────────────────────────────────────────────────────────────

# Database
POSTGRES_USER=jade
POSTGRES_PASSWORD=jade123
POSTGRES_DB=jade_capital
DATABASE_URL=postgresql://jade:jade123@localhost:5432/jade_capital

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT
JWT_SECRET=jade-capital-v3-super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Ports
PORT=3000
FRONTEND_PORT=8080

# AI / LLM (optional)
OPENAI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Market Data (optional)
TWELVEDATA_API_KEY=demo
POLYGON_API_KEY=
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
