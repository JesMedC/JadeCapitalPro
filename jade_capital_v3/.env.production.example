# JadeCapital v3 — Hostinger VPS production environment
# Copy to .env on the VPS and change every secret before `docker compose up`.

POSTGRES_USER=jade
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=jade_capital

REDIS_PASSWORD=

JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS_REFRESH_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Replace with your real domain once DNS points to the VPS.
APP_ORIGIN=https://your-domain.com
CORS_ORIGINS=https://your-domain.com,http://your-server-ip

# Optional market/AI providers
OPENAI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
TWELVEDATA_API_KEY=demo
POLYGON_API_KEY=
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
