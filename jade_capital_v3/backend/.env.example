# ─── Environment ───
NODE_ENV=development
PORT=3000

# ─── CORS ───
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── PostgreSQL ───
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=jade_capital_v3

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-random-long-string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Scanner ───
# Set to true to enable the background harmonic pattern scanner (cron: every 15 min)
SCANNER_ENABLED=false
